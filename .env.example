# Copy to .env and fill in your values
GA_LANG=en

# Global proxy (optional)
# PROXY=http://127.0.0.1:2082

# Langfuse tracing (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# Skill search API endpoint (optional)
# SKILL_SEARCH_API=http://www.fudankw.cn:58787

# Autonomous mode (optional)
# Set to "true" or "1" to enable autonomous background mode
# AUTONOMOUS_MODE=

# Autonomous check interval in seconds (default: 1800 = 30 min)
# AUTONOMOUS_INTERVAL=

# Working directory for agent operations (default: ./temp)
# GA_WORKDIR=

# Maximum LLM turns per task (default: 40)
# GA_MAX_TURNS=

# Langfuse trace sample rate (0.0-1.0, default: 1.0)
# LANGFUSE_SAMPLE_RATE=

# Global request timeout in seconds (default: 300)
# GA_REQUEST_TIMEOUT=
